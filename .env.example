# Fimbulwinter Lite — deploy.sh credentials (copy to .env, which is gitignored)

# Pelican panel base URL (the panel, not Wings)
PANEL_URL=https://panel.example.lan

# Client API key: Panel -> Account -> API Credentials (starts with ptlc_)
PELICAN_CLIENT_KEY=ptlc_xxxxxxxxxxxxxxxxxxxxxxxx

# Server short identifier: visible in the panel URL /server/<SERVER_ID>
SERVER_ID=xxxxxxxx
